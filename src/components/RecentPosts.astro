---
// 1. 引入 Astro 原生内容集合方法
import { getCollection } from "astro:content";

// 2. 获取所有的博客文章，并按照日期倒序排列，最后只取前 3 篇
const allPosts = await getCollection("blog");
const recentPosts = allPosts
	.sort((a, b) => {
		const dateA = a.data.date ? new Date(a.data.date).valueOf() : 0;
		const dateB = b.data.date ? new Date(b.data.date).valueOf() : 0;
		return dateB - dateA; // 最新发布的排在最前
	})
	.slice(0, 3); // 🌟 核心：切片函数，只保留前 3 篇
---

<section id="recent-blog">
	<div class="container">
		<!-- 头部标题区 -->
		<div class="section-header">
			<div class="header-left">
				<h2>Stay Updated With Our Tips & Industry News!</h2>
			</div>
			<div class="header-right">
				<span class="sub-title">Our Blog</span>
				<p>Stay informed with our latest sustainable bamboo insights, manufacturing updates, and expert advice.</p>
				<a href="/blog/" class="view-all-link">All news ➔</a>
			</div>
		</div>

		<hr class="section-divider" />

		<!-- 3篇博客卡片网格 -->
		<div class="blog-grid">
			{
				recentPosts.map((post) => {
					// 格式化日期显示（例如：Jul 4, 2026）
					const formattedDate = post.data.date 
						? new Date(post.data.date).toLocaleDateString('en-US', {
								month: 'short',
								day: 'numeric',
								year: 'numeric'
						  })
						: "";

					// 🌟 安全获取图片路径：如果是对象则取 .src，如果是字符串直接用，没有则用默认图
					const imageSrc = post.data.image 
						? (typeof post.data.image === 'object' ? post.data.image.src : post.data.image)
						: "/assets/images/default-blog.jpg";

					return (
						<article class="blog-card">
							<div class="image-wrapper">
								<a href={`/blog/${post.slug}/`}>
									<img 
										src={imageSrc} 
										alt={post.data.title}
										loading="lazy"
									/>
								</a>
							</div>
							
							<div class="card-meta">
								{post.data.tags && post.data.tags[0] && (
									<span class="category-badge">{post.data.tags[0]}</span>
								)}
								<span class="post-date">{formattedDate}</span>
							</div>

							<h3 class="card-title">
								<a href={`/blog/${post.slug}/`}>{post.data.title}</a>
							</h3>

							<p class="card-description">
								{post.data.description || post.body?.slice(0, 100) + "..."}
							</p>

							<a href={`/blog/${post.slug}/`} class="read-more-btn">
								Read more ↗
							</a>
						</article>
					);
				})
			}
		</div>
	</div>
</section>

<style>

/* 基础网格与响应式布局 CSS */

#recent-blog {

padding: 60px 0;

background-color: #ffffff;

}

.container {

max-width: 1200px;

margin: 0 auto;

padding: 0 20px;

}

.section-header {

display: flex;

justify-content: space-between;

align-items: flex-start;

flex-wrap: wrap;

gap: 20px;

}

.header-left h2 {

font-size: 2.2rem;

font-weight: 700;

max-width: 500px;

line-height: 1.2;

margin: 0;

color: #1a1a1a;

}

.header-right {

max-width: 500px;

position: relative;

}

.sub-title {

font-weight: 700;

color: #1a1a1a;

display: block;

margin-bottom: 5px;

}

.view-all-link {

color: #7ca922; /* 匹配您的企业绿 */

text-decoration: none;

font-weight: 600;

position: absolute;

top: 0;

right: 0;

}

.section-divider {

border: 0;

height: 1px;

background-color: #cbd5e1;

margin: 30px 0;

}

.blog-grid {

display: grid;

grid-template-columns: repeat(3, 1fr);

gap: 30px;

}

@media (max-width: 992px) {

.blog-grid { grid-template-columns: repeat(2, 1fr); }

}

@media (max-width: 768px) {

.blog-grid { grid-template-columns: 1fr; }

.view-all-link { position: static; display: inline-block; margin-top: 10px; }

}

.blog-card {

display: flex;

flex-direction: column;

}

.image-wrapper {

width: 100%;

border-radius: 12px;

overflow: hidden;

aspect-ratio: 16 / 9;

margin-bottom: 15px;

}

.image-wrapper img {

width: 100%;

height: 100%;

object-fit: cover;

transition: transform 0.3s ease;

}

.image-wrapper:hover img {

transform: scale(1.05);

}

.card-meta {

display: flex;

align-items: center;

gap: 15px;

margin-bottom: 10px;

font-size: 0.85rem;

color: #64748b;

}

.category-badge {

border: 1px solid #1a1a1a;

padding: 2px 10px;

border-radius: 20px;

text-transform: uppercase;

font-size: 0.75rem;

font-weight: 600;

color: #1a1a1a;

}

.card-title {

font-size: 1.3rem;

font-weight: 700;

margin: 0 0 10px 0;

line-height: 1.3;

}

.card-title a {

color: #1a1a1a;

text-decoration: none;

}

.card-title a:hover {

color: #7ca922;

}

.card-description {

color: #475569;

font-size: 0.95rem;

line-height: 1.5;

margin: 0 0 15px 0;

display: -webkit-box;

-webkit-line-clamp: 3;

-webkit-box-orient: vertical;

overflow: hidden;

}

.read-more-btn {

align-self: flex-start;

border: 1px solid #1a1a1a;

padding: 6px 18px;

border-radius: 6px;

color: #1a1a1a;

text-decoration: none;

font-size: 0.9rem;

font-weight: 500;

transition: all 0.2s ease;

}

.read-more-btn:hover {

background-color: #1a1a1a;

color: #ffffff;

}

    /* 优化新博客区域的整体标题和文本大小 */

    #recent-blog {

        padding: 60px 0; /* 顺便给上下留出足够的呼吸空间 */

    }



    /* 1. 让左侧的主标题更大、更粗、更有分量 */

        #recent-blog .header-left h2 {

        font-size: 2.5rem;          /* 显著放大字号，向FAQ看齐 */

        font-weight: 800;           /* 极粗体，提升视觉冲击力 */

        line-height: 1.2;

        color: #111111;             /* 保证颜色足够深 */

        letter-spacing: -0.02em;    /* 大标题稍微紧凑一点更好看 */

        margin: 0;

    }



    /* 2. 优化右侧的小标题 "Our Blog" */

        #recent-blog .header-right .sub-title {

        font-size: 1.1rem;

        font-weight: 700;

        text-transform: uppercase;  /* 保持大写风格 */

        letter-spacing: 0.05em;

        color: #333;

    }



    /* 3. 放大右侧的简介文本 */

        #recent-blog .header-right p {

        font-size: 1.125rem;        /* 调整到 18px 左右，更易读 */

        line-height: 1.6;

        color: #4a4a4a;             /* 稍微加深一点颜色，提升对比度 */

        margin: 8px 0 15px 0;

    }



    /* 4. 顺便让 "All news ➔" 链接也更清晰醒目 */

        #recent-blog .view-all-link {

        font-size: 1.05rem;

        font-weight: 600;

    }
</style> 