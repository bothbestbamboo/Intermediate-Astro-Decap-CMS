---
// Utils
import { getImage } from "astro:assets";

// Components
import BaseLayout from "@layouts/BaseLayout.astro";
import Banner from "@components/Banner/Banner.astro";
import Gallery from "@components/Gallery/Gallery.astro";
import CTA from "@components/CTA/CTASimple.astro";

// Images
import landingImage from "@assets/images/gallery/bannerproduct.jpg";
const optimizedImage = await getImage({ src: landingImage, format: "webp" });
---

<BaseLayout title="Products" description="Bothbest is a professional manufacturer and exporter of bamboo panels, bamboo veneer, and bamboo flooring in China" heroImage={optimizedImage}>
	<Banner title="All About Bamboo" image={optimizedImage} />
	<Gallery />
	<CTA />
</BaseLayout>
