---
// 🌟 移除容易在不同版本下报错的组件导入，改用 100% 稳妥的静态资产/或者原项目标准格式
---

<section id="services" class="services">
  <div class="card">
    <picture>
      <img src="/assets/svgs/service1.svg" width="48" height="48" alt="Bamboo Flooring Icon" aria-hidden="true" class="service-icon-img" onerror="this.style.display='none'" />
    </picture>
    <h2>Bamboo Flooring</h2>
    <p>
      Premium solid, engineered, and strand woven bamboo flooring designed for modern interiors. It delivers exceptional wear resistance, natural warmth, and eco-friendly elegance to any residential or commercial space.
    </p>
  </div>
  <div class="card">
    <picture>
      <img src="/assets/svgs/service2.svg" width="48" height="48" alt="Bamboo Decking Icon" aria-hidden="true" class="service-icon-img" onerror="this.style.display='none'" />
    </picture>
    <h2>Bamboo Decking</h2>
    <p>
      High-density, exterior-grade strand woven bamboo decking engineered to withstand harsh outdoor elements. Featuring superior anti-corrosion, mold-resistance, and high stability, it is perfect for luxury patios, gardens, and commercial walkways.
    </p>
  </div>
  <div class="card">
    <picture>
      <img src="/assets/svgs/service3.svg" width="48" height="48" alt="Bamboo Plywood Icon" aria-hidden="true" class="service-icon-img" onerror="this.style.display='none'" />
    </picture>
    <h2>Bamboo Plywood</h2>
    <p>
      Multi-layer, high-strength architectural bamboo plywood. Ideal for high-end furniture manufacturing, tabletops, and interior design, offering a perfect sustainable alternative to traditional hardwood with superior structural integrity.
    </p>
  </div>
</section>

<style lang="less">
  /*-- -------------------------- -->
<---          Services          -->
<--- -------------------------- -*/

  /* Mobile */
  @media only screen and (min-width: 0em) {
    .services {
      width: 90%;
      max-width: (1320/16em);
      margin: auto;
      margin-top: (-60/16em); 
      margin-bottom: (50/16em);
      padding: (40/16em) (20/16em);
      background: #fff;
      box-shadow: 0px 20px 40px rgba(0, 0, 0, 0.05);
      border-top: (6/16em) solid var(--primary);
      border-radius: (5/16em);
      position: relative;
      z-index: 100;
      box-sizing: border-box;

      .card {
        width: 100%;
        max-width: (357/16em);
        margin: auto;
        margin-bottom: (40/16em);
        display: block;
        box-sizing: border-box;

        &:last-of-type {
          margin-bottom: 0;
        }

        picture {
          width: (88/16em);
          height: (88/16em);
          margin: auto;
          margin-bottom: (20/16em);
          background: var(--primary);
          border-radius: 50%;
          display: flex;
          justify-content: center;
          align-items: center;

          /* 🌟 确保原生 img 的色彩和缩放与之前保持完全一致 */
          .service-icon-img { 
            width: (48/16em);
            height: (48/16em);
            display: block;
            object-fit: contain;
          }
        }
        h2 {
          font-size: (22/16em); 
          font-weight: 700;
          line-height: 1.3; 
          text-align: center;
          margin-bottom: (12/16em);
          color: #1a1a1a;
          padding: 0 (10/16em); 
        }
        p {
          font-size: (14/16em); 
          line-height: 1.5;
          text-align: center;
          width: 100%;
          opacity: 0.7;
          margin: 0;
          color: #4a4a4a;
        }
      }
    }
  }

  /* Inbetween / Tablet */
  @media only screen and (min-width: 768px) {
    .services {
      font-size: ~"min(1.8vw, 1em)";
      width: 98%;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-top: (-167/16em); 

      .card {
        max-width: (325/16em);
        margin: 0;
        margin-bottom: 0;

        h2 {
          font-size: (32/16em); 
          line-height: 27/20em;
          padding: 0;
        }
        p {
          font-size: 1em;
        }
      }
    }
  }

  /* Large Desktop */
  @media only screen and (min-width: 1300px) {
    .services {
      padding: (50/16em) (80/16em);

      .card {
        max-width: (357/16em);
      }
    }
  }

  /* Dark mode */
  @media only screen and (min-width: 0em) {
    body.dark-mode {
      #services {
        background: var(--medium);

        picture {
          background: var(--primaryDark);
        }

        h2 {
          font-weight: bold;
          color: #fff;
        }
        p {
          color: #cccccc;
        }
      }
    }
  }
</style>