---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import { formatDate } from "@js/utils";
// 🌟 直接引入最核心的全站骨架，彻底摆脱博客布局的枷锁
import BaseLayout from "@layouts/BaseLayout.astro"; 

export async function getStaticPaths() {
	const products = await getCollection("products");
	return products.map((entry) => ({
		params: { product: entry.id },
		props: { product: entry },
	}));
}

const { product } = Astro.props;
const { title, description, image, imageAlt, tags } = product.data;

// 1. 获取所有产品，用来做底部的相同标签相关产品推荐
const allProducts = await getCollection("products");
const currentTags = tags || ["Products"];
const relatedProducts = allProducts
	.filter((item) => {
		const hasCommonTag = item.data.tags?.some(tag => currentTags.includes(tag));
		return hasCommonTag && item.id !== product.id;
	})
	.slice(0, 3);

// 2. 正确渲染当前产品的 Markdown 核心内容
const { Content } = await render(product);

const safeAltText = imageAlt || title || "Bothbest Bamboo Product";
---

<BaseLayout title={title} description={description || "Bothbest Premium Bamboo Product"} heroImage={image}>
	
	<div class="product-page-container">
		
		<!-- 产品面包屑 / 分类小标签 -->
		<header class="product-page-header">
			<span class="prod-tag-top">{currentTags[0]}</span>
			<h1>{title}</h1>
		</header>

		<!-- 🌟 双栏商务核心布局结构 -->
		<div class="product-detail-container">
			
			<!-- 左栏：主图 + 产品 Markdown 核心描述 -->
			<div class="product-main-content">
				<!-- 产品主图（复刻原博客大图的精美质感） -->
				{image && (
					<picture class="product-mainImage">
						<Image src={image} alt={safeAltText} width="795" height="440" decoding="async" />
					</picture>
				)}

				<!-- Markdown 正文渲染区 -->
				<div id="product-markdown-body">
					<Content />
				</div>
			</div>

			<!-- 右栏：高转化商务互动边栏 -->
			<aside class="product-sidebar">
				<!-- 模块一：在线询盘定位组件 -->
				<div class="sidebar-card inquiry-card">
					<h3>Interested in this Product?</h3>
					<p>Get instant factory-direct pricing, custom specifications, and material samples for your projects.</p>
					<!-- 🌟 精准定位至联系页面的表单 -->
					<a href="/contact/#cs-form" class="sidebar-inquiry-btn">
						Inquire Now ➔
					</a>
				</div>

				<!-- 模块二：标签分类快速筛选 -->
				{currentTags.length > 0 && (
					<div class="sidebar-card tags-card">
						<h4>Product Categories</h4>
						<div class="sidebar-tags-list">
							{currentTags.map((tag) => (
								<span class="sidebar-tag-item">{tag}</span>
							))}
						</div>
					</div>
				)}
			</aside>
		</div>

		<!-- 下方：相关产品推荐区域 -->
		{relatedProducts.length > 0 && (
			<div class="related-products-section">
				<hr class="related-divider" />
				<h3 class="related-section-title">Related Bamboo Products</h3>
				<div class="related-grid">
					{relatedProducts.map((item) => {
						const itemImage = item.data.image 
							? (typeof item.data.image === 'object' ? item.data.image.src : item.data.image)
							: "/assets/images/default-product.jpg";
						return (
							<div class="related-card">
								<a href={`/products/${item.id}/`} class="img-link">
									<img src={itemImage} alt={item.data.title} loading="lazy" />
								</a>
								<div class="related-info">
									<h4><a href={`/products/${item.id}/`}>{item.data.title}</a></h4>
									<a href={`/products/${item.id}/`} class="view-detail-link">View Details ↗</a>
								</div>
							</div>
						);
					})}
				</div>
			</div>
		)}
	</div>
</BaseLayout>

<style lang="less">
	/* ==========================================================================
	   独立产品框架容器（严格对齐博客页面的宽度体系）
	   ========================================================================== */
	.product-page-container {
		width: 94%;
		max-width: (1120/16em);
		margin: auto;
		padding: clamp(60px, 7vw, 100px) 0;
		box-sizing: border-box;
	}

	.product-page-header {
		margin-bottom: clamp(30px, 5vw, 50px);
		
		.prod-tag-top {
			font-size: 14px;
			font-weight: 700;
			color: #a3e635; /* 工厂标志荧光绿 */
			text-transform: uppercase;
			letter-spacing: 0.1em;
			display: inline-block;
			margin-bottom: 8px;
		}

		h1 {
			font-size: clamp(24px, 5vw, 39px);
			font-weight: 700;
			line-height: 1.4em;
			color: var(--headerColor, #111111);
			margin: 0;
		}
	}

	/* ==========================================================================
	   双栏响应式布局
	   ========================================================================== */
	.product-detail-container {
		display: flex;
		flex-direction: column;
		row-gap: (50/16em);
		width: 100%;

		@media only screen and (min-width: 64em) {
			flex-direction: row;
			align-items: flex-start;
			column-gap: (48/16em);
		}
	}

	.product-main-content {
		width: 100%;
		max-width: (795/16em);
		flex: 1;

		.product-mainImage {
			width: 100%;
			height: clamp(220px, 35vw, 440px);
			margin-bottom: (40/16em);
			border-radius: (8/16em);
			display: block;
			position: relative;
			overflow: hidden;

			img {
				width: 100%;
				height: 100%;
				object-fit: cover;
			}
		}
	}

	/* Markdown 内部排修 */
	#product-markdown-body {
		font-size: 16px;
		line-height: 1.7;
		color: var(--bodyTextColor, #333333);
		
		p { margin-bottom: 20px; }
		h2, h3 { color: var(--headerColor, #111111); margin: 30px 0 15px 0; }
	}

	/* ==========================================================================
	   右侧高端商务边栏
	   ========================================================================== */
	.product-sidebar {
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 24px;

		@media only screen and (min-width: 64em) {
			width: (320/16em);
			flex-shrink: 0;
			position: sticky;
			top: 100px;
		}

		.sidebar-card {
			background: #f9fafb;
			border: 1px solid #e5e7eb;
			border-radius: 8px;
			padding: 24px;
		}

		.inquiry-card {
			border-left: 4px solid #a3e635;
			h3 { font-size: 18px; font-weight: 700; color: #111111; margin: 0 0 12px 0; }
			p { font-size: 14px; line-height: 1.5; color: #666666; margin: 0 0 20px 0; }
			
			.sidebar-inquiry-btn {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 100%;
				padding: 12px;
				background-color: #111111;
				color: #ffffff !important;
				font-size: 13px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				text-decoration: none;
				border-radius: 4px;
				transition: all 0.3s ease;
				&:hover { background-color: #a3e635; color: #111111 !important; }
			}
		}

		.tags-card {
			h4 { font-size: 14px; font-weight: 700; color: #111111; margin: 0 0 14px 0; text-transform: uppercase; }
			.sidebar-tags-list { display: flex; flex-wrap: wrap; gap: 8px; }
			.sidebar-tag-item { font-size: 12px; font-weight: 600; background-color: #ffffff; border: 1px solid #e5e7eb; color: #4a4a4a; padding: 5px 10px; border-radius: 4px; }
		}
	}

	/* ==========================================================================
	   底部横向循环推荐
	   ========================================================================== */
	.related-products-section {
		margin-top: 60px;
		width: 100%;
		
		.related-divider { border: 0; height: 1px; background-color: #e5e7eb; margin-bottom: 40px; }
		.related-section-title { font-size: 24px; font-weight: 700; color: var(--headerColor, #111111); margin: 0 0 24px 0; }
		.related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 24px; }
		
		.related-card {
			background: #ffffff;
			border: 1px solid #e5e7eb;
			border-radius: 8px;
			overflow: hidden;
			display: flex;
			flex-direction: column;
			transition: transform 0.3s ease, box-shadow 0.3s ease;
			&:hover { transform: translateY(-4px); box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05); }
			
			.img-link {
				width: 100%;
				aspect-ratio: 16 / 10;
				overflow: hidden;
				display: block;
				img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease; }
			}
			&:hover .img-link img { transform: scale(1.05); }
			
			.related-info {
				padding: 16px;
				display: flex;
				flex-direction: column;
				flex: 1;
				h4 { font-size: 16px; font-weight: 700; margin: 0 0 12px 0; line-height: 1.4;
					a { color: var(--headerColor, #111111); text-decoration: none; &:hover { color: #a3e635; } }
				}
				.view-detail-link { font-size: 13px; font-weight: 600; color: #666666; text-decoration: none; margin-top: auto; &:hover { color: #a3e635; } }
			}
		}
	}

	/* ==========================================================================
	   Dark Mode 全黑适配
	   ========================================================================== */
	body.dark-mode {
		.product-page-header h1, #product-markdown-body h2, #product-markdown-body h3 { color: #f7f7f7; }
		#product-markdown-body { color: #cccccc; }
		.product-sidebar {
			.sidebar-card { background: #1a1a1a; border-color: #333333; }
			.inquiry-card h3, .tags-card h4 { color: #ffffff; }
			.inquiry-card p { color: #999999; }
			.tags-card .sidebar-tag-item { background-color: #262626; border-color: #404040; color: #cccccc; }
		}
		.related-products-section {
			.related-divider { background-color: #333333; }
			.related-card {
				background: #111111; border-color: #333333;
				.related-info h4 a { color: #f7f7f7; }
				.related-info .view-detail-link { color: #999999; }
			}
		}
	}
</style>