---
/**
 * * A simple banner used on every page except the homepage
 * * Takes a title, an optional subtitle, and an image as props
 */

// Utils
import { Picture } from "astro:assets";
import type { GetImageResult } from "astro";

interface Props {
	title: string; // heading text
	subtitle?: string; // 新增：副标题文字（?表示可选）
	image: GetImageResult; // pre-optimized image from getImage()
}

const { title, subtitle, image } = Astro.props; // 新增：在这里解构出 subtitle
---

<section id="int-hero">
	<h1 id="home-h">{title}</h1>

	{subtitle && <p>{subtitle}</p>}

	<Picture
		src={image.src}
		width={image.attributes.width}
		height={image.attributes.height}
		formats={["avif", "webp"]}
		alt=""
		priority
	/>
</section>

<style lang="less">
	/*-- -------------------------- -->
<---   Interior Page Header     -->
<--- -------------------------- -*/

	/* Mobile */
	@media only screen and (min-width: 0em) {
		#int-hero {
			min-height: 30vh;
			padding-top: (50/16rem);
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-items: center;
			position: relative;
			z-index: 1;

			&:before {
				content: "";
				width: 100%;
				height: 100%;
				background: #000;
				opacity: 0.7;
				display: block;
				position: absolute;
				top: 0;
				left: 0;
				z-index: -1;
			}

			picture {
				width: 100%;
				height: 100%;
				position: absolute;
				top: 0;
				left: 0;
				z-index: -2;

				img {
					width: 100%;
					height: 100%;
					object-fit: cover;
					position: absolute;
					top: 0;
					left: 0;
				}
			}

			h1 {
				font-size: var(--headerFontSize);
				text-align: center;
				width: 96%;
				max-width: (500/16rem);
				margin: 0 auto;
				margin-top: (70/16rem);
				margin-bottom: (
					10/16rem
				); /* 调整了下边距，让它和副标题更紧凑 */
				color: #fff;
				position: relative;
			}

			p {
				text-align: center;
				width: 96%;
				/* 将最大宽度改为 800px 左右，或者设为 none。这样长句子就能在同一行拉开 */
				max-width: (850/16rem);
				margin: auto;
				margin-top: (10/16rem); /* 适当加一点和主标题的间距 */
				margin-bottom: (30/16rem);
				color: #fff;
				display: block;
				position: relative;
				z-index: 1;

				/* 优化：为了防止单词在中间被生硬截断，可以加上这行 */
				word-wrap: break-word;
			}
		}
	}

	/* Small Desktop */
	@media only screen and (min-width: 64em) {
		#int-hero {
			height: auto;
			min-height: (300/16rem);
			padding-top: (180/16rem);
			background-attachment: fixed;
			padding-block-end: (100/16rem);
		}

		/* 电脑端可以让副标题稍微宽一点，显示更美观 */
		#int-hero p {
			max-width: (600/16rem);
		}
	}
</style>
