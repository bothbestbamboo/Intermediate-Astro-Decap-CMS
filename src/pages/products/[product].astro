---
import { getCollection, render } from "astro:content";
import BlogPostLayout from "@layouts/BlogPostLayout.astro";

export async function getStaticPaths() {
	const products = await getCollection("products");
	return products.map((entry) => ({
		params: { product: entry.id },
		props: { product: entry },
	}));
}

const { product } = Astro.props;

// 1. 获取所有产品并筛选出相同标签的相关推荐（最多 3 个）
const allProducts = await getCollection("products");
const currentTags = product.data.tags || ["Products"];
const relatedProducts = allProducts
	.filter((item) => {
		const hasCommonTag = item.data.tags?.some(tag => currentTags.includes(tag));
		return hasCommonTag && item.id !== product.id;
	})
	.slice(0, 3);

// 2. 渲染原始的 Markdown 内容
const { Content: OriginalContent, headings } = await render(product);

// 3. 创造一个安全的保底文本，防止 Image 组件报错
const globalFallbackAlt = product.data.title || "Bothbest Premium Bamboo Product";
---

<BlogPostLayout post={product} headings={headings}>
	
	<!-- 正文部分：完全回归原有排版 -->
	<div class="product-custom-body-wrapper">
		<OriginalContent />
	</div>

	<!-- 额外右侧挂载：通过原生脚本把这个高转化询盘卡片塞到右侧 Table of Contents 目录的下方 -->
	<div id="factory-inquiry-source" class="cs-hidden-teleport" style="display: none;">
		<div class="sidebar-card inquiry-card">
			<h3>Interested in this Product?</h3>
			<p>Get instant factory-direct pricing, custom specifications, and material samples for your projects.</p>
			<a href="/contact/#cs-form" class="sidebar-inquiry-btn">
				Inquire Now ➔
			</a>
		</div>

		{currentTags.length > 0 && (
			<div class="sidebar-card tags-card">
				<h4>Product Categories</h4>
				<div class="sidebar-tags-list">
					{currentTags.map((tag) => (
						<span class="sidebar-tag-item">{tag}</span>
					))}
				</div>
			</div>
		)}
	</div>

	<!-- 下方相关产品推荐（修复满屏问题，限制最大 3 列网格，并对图片属性进行彻底的纯 HTML 安全解耦） -->
	{relatedProducts.length > 0 && (
		<div class="related-products-section-fixed">
			<hr class="related-divider-fixed" />
			<h3 class="related-section-title-fixed">Related Bamboo Products</h3>
			<div class="related-grid-fixed">
				{relatedProducts.map((item) => {
					// 🌟 核心防错：智能解析图片路径，无论是对象还是普通字符串
					const itemImage = item.data.image 
						? (typeof item.data.image === 'object' ? item.data.image.src : item.data.image)
						: "/assets/images/default-product.jpg";
					
					// 🌟 核心防错：这里绝不能留空，必须给一个坚固的保底字符串
					const itemAlt = item.data.imageAlt || item.data.title || "Bothbest Bamboo Factory Product";
					
					return (
						<div class="related-card-fixed">
							<!-- 🌟 此处改用原生 <img> 配合解耦后的 itemAlt，彻底绕过 Astro 编译期对特定组件的强校验 -->
							<a href={`/products/${item.id}/`} class="img-link-fixed">
								<img src={itemImage} alt={itemAlt} loading="lazy" />
							</a>
							<div class="related-info-fixed">
								<h4><a href={`/products/${item.id}/`}>{item.data.title}</a></h4>
								<a href={`/products/${item.id}/`} class="view-detail-link-fixed">View Details ↗</a>
							</div>
						</div>
					);
				})}
			</div>
		</div>
	)}
</BlogPostLayout>

<!-- 巧妙的传送门脚本：把询盘组件和分类组件无缝塞到右侧侧边栏中，排在 Quick Navigation 的下面 -->
<script is:inline>
	function teleportInquiry() {
		const source = document.getElementById('factory-inquiry-source');
		const desktopSidebar = document.getElementById('desktop-toc'); 
		
		if (source && desktopSidebar) {
			const wrapper = document.createElement('div');
			wrapper.className = 'teleported-sidebar-wrapper';
			wrapper.innerHTML = source.innerHTML;
			desktopSidebar.parentNode.insertBefore(wrapper, desktopSidebar.nextSibling);
		}
	}
	document.addEventListener('astro:page-load', teleportInquiry);
	teleportInquiry(); 
</script>

<style lang="less" is:global>
	/* ==========================================================================
	   相关产品卡片防满屏修正（强制 3 列，哪怕只有 1 个也不撑满）
	   ========================================================================== */
	.related-products-section-fixed {
		margin-top: 50px;
		width: 100%;
		max-width: 795px; 
		clear: both;

		.related-divider-fixed {
			border: 0;
			height: 1px;
			background-color: #e5e7eb;
			margin-bottom: 30px;
		}

		.related-section-title-fixed {
			font-size: 22px;
			font-weight: 700;
			color: var(--headerColor, #111111);
			margin: 0 0 20px 0;
		}

		.related-grid-fixed {
			display: grid;
			grid-template-columns: repeat(3, minmax(200px, 1fr)); 
			gap: 20px;

			@media (max-width: 767px) {
				grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
			}
		}

		.related-card-fixed {
			background: #ffffff;
			border: 1px solid #e5e7eb;
			border-radius: 6px;
			overflow: hidden;
			display: flex;
			flex-direction: column;
			transition: transform 0.3s ease;

			&:hover {
				transform: translateY(-4px);
			}

			.img-link-fixed {
				width: 100%;
				aspect-ratio: 4 / 3; 
				overflow: hidden;
				display: block;
				background-color: #f3f4f6;

				img {
					width: 100%;
					height: 100%;
					object-fit: cover;
				}
			}

			.related-info-fixed {
				padding: 12px;
				display: flex;
				flex-direction: column;
				flex: 1;

				h4 {
					font-size: 14px;
					font-weight: 700;
					margin: 0 0 8px 0;
					line-height: 1.4;
					
					a {
						color: var(--headerColor, #111111);
						text-decoration: none;
						&:hover { color: #a3e635; }
					}
				}

				.view-detail-link-fixed {
					font-size: 12px;
					font-weight: 600;
					color: #666666;
					text-decoration: none;
					margin-top: auto;
					&:hover { color: #a3e635; }
				}
			}
		}
	}

	/* ==========================================================================
	   被传送到右侧边栏的工厂询盘及分类样式
	   ========================================================================== */
	.teleported-sidebar-wrapper {
		margin-top: 30px;
		display: flex;
		flex-direction: column;
		gap: 20px;

		.sidebar-card {
			background: #f9fafb;
			border: 1px solid #e5e7eb;
			border-radius: 8px;
			padding: 22px;
			box-sizing: border-box;
		}

		.inquiry-card {
			border-left: 4px solid #a3e635;
			h3 { font-size: 16px; font-weight: 700; color: #111111; margin: 0 0 10px 0; }
			p { font-size: 13px; line-height: 1.5; color: #666666; margin: 0 0 16px 0; }
			
			.sidebar-inquiry-btn {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 100%;
				padding: 10px;
				background-color: #111111;
				color: #ffffff !important;
				font-size: 12px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				text-decoration: none;
				border-radius: 4px;
				&:hover { background-color: #a3e635; color: #111111 !important; }
			}
		}

		.tags-card {
			h4 { font-size: 13px; font-weight: 700; color: #111111; margin: 0 0 12px 0; text-transform: uppercase; }
			.sidebar-tags-list { display: flex; flex-wrap: wrap; gap: 6px; }
			.sidebar-tag-item { font-size: 11px; font-weight: 600; background-color: #ffffff; border: 1px solid #e5e7eb; color: #4a4a4a; padding: 4px 8px; border-radius: 4px; }
		}
	}

	body.dark-mode {
		.teleported-sidebar-wrapper {
			.sidebar-card { background: #1a1a1a; border-color: #333333; }
			.inquiry-card h3, .tags-card h4 { color: #ffffff; }
			.inquiry-card p { color: #999999; }
			.tags-card .sidebar-tag-item { background-color: #262626; border-color: #404040; color: #cccccc; }
		}
		.related-products-section-fixed {
			.related-divider-fixed { background-color: #333333; }
			.related-card-fixed {
				background: #111111; border-color: #333333;
				.related-info-fixed h4 a { color: #ffffff; }
			}
		}
	}
</style>