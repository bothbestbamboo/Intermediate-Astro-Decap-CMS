---
// 1. 引入 Astro 原生内容集合方法
import { getCollection } from "astro:content";

// 2. 获取所有的博客文章，并按照日期倒序排列，最后只取前 3 篇
const allPosts = await getCollection("blog");
const recentPosts = allPosts
	.sort((a, b) => {
		const dateA = a.data.date ? new Date(a.data.date).valueOf() : 0;
		const dateB = b.data.date ? new Date(b.data.date).valueOf() : 0;
		return dateB - dateA; // 最新发布的排在最前
	})
	.slice(0, 3); // 只保留前 3 篇
---

<section id="recent-blog">
	<div class="container">
		<div class="section-header">
			<div class="header-left">
				<h2>Insights From the Forefront of Bamboo Innovation</h2>
			</div>
			
			<div class="header-right">
				<div class="meta-row">
					<span class="sub-title">INDUSTRY LEADERSHIP</span>
					<a href="/blog/" class="view-all-link">View insights ➔</a>
				</div>
				
				<p>Explore our technical analysis, sustainable manufacturing updates, and architectural inspiration curated by experts who understand the true potential of premium bamboo materials.</p>
			</div>
		</div>

		<hr class="section-divider" />

		<div class="blog-grid">
			{
				recentPosts.map((post) => {
					// 格式化日期显示（例如：Jul 4, 2026）
					const formattedDate = post.data.date 
						? new Date(post.data.date).toLocaleDateString('en-US', {
								month: 'short',
								day: 'numeric',
								year: 'numeric'
						  })
						: "";

					// 安全获取图片路径
					const imageSrc = post.data.image 
						? (typeof post.data.image === 'object' ? post.data.image.src : post.data.image)
						: "/assets/images/default-blog.jpg";

					return (
						<article class="blog-card">
							<div class="image-wrapper">
								<a href={`/blog/${post.id}/`}>
									<img 
										src={imageSrc} 
										alt={post.data.title}
										loading="lazy"
									/>
								</a>
							</div>
							
							<div class="card-meta">
								{post.data.tags && post.data.tags[0] && (
									<span class="category-badge">{post.data.tags[0]}</span>
								)}
								<span class="post-date">{formattedDate}</span>
							</div>

							<h3 class="card-title">
								<a href={`/blog/${post.id}/`}>{post.data.title}</a>
							</h3>

							<p class="card-description">
								{post.data.description || post.body?.slice(0, 100) + "..."}
							</p>

							<a href={`/blog/${post.id}/`} class="read-more-btn">
								Read more ↗
							</a>
						</article>
					);
				})
			}
		</div>
	</div>
</section>

<style lang="less">
	/* ==========================================================================
	   容器与头部布局
	   ========================================================================== */
	#recent-blog {
		padding: var(--sectionPadding, 80px 0);
		background-color: #ffffff;
		
		.container {
			width: 100%;
			max-width: (1322/16em);
			margin: 0 auto;
			padding: 0 (16/16rem);
			box-sizing: border-box;
		}
	}

	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: (40/16rem);
		flex-wrap: wrap;
	}

	.header-left {
		flex: 1;
		min-width: (320/16rem);
		
		h2 {
			font-size: ~"min(2.5rem, 6vw)";
			font-weight: 800;
			color: #111111;
			line-height: 1.2;
			margin: 0;
		}
	}

	.header-right {
		max-width: (500/16em);
		flex-grow: 1;
		display: flex;
		flex-direction: column;
		
		p {
			font-size: (18/16rem);
			line-height: 1.6;
			color: #4a4a4a;
			margin: 0;
		}
	}

	.meta-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		width: 100%;
		margin-bottom: (12/16rem);
	}

	.sub-title {
		font-size: (16/16rem);
		font-weight: 700;
		color: #333333;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin: 0;
	}

	.section-divider {
		border: 0;
		height: 1px;
		background-color: #e5e7eb;
		margin: (40/16rem) 0;
	}

	/* ==========================================================================
	   VIEW INSIGHTS 按钮 (严格从左往右滑动变黑)
	   ========================================================================== */
	.view-all-link {
		font-size: (16/16rem);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		text-decoration: none;
		padding: (12/16rem) (24/16rem); /* 严格对齐主按钮高度 */
		background-color: #a3e635;
		color: #111111 !important;
		border-radius: 4px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 6px;
		position: relative; 
		overflow: hidden;
		z-index: 1;                  
		transition: color 0.3s ease;
	}

	.view-all-link::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background-color: #111111;
		z-index: -1;                 
		
		/* 🌟 修复点：改回 scaleX，并且把基准点锁在左边，实现从左往右铺满 */
		transform: scaleX(0);
		transform-origin: left;
		border-radius: 4px;
		transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	/* 电脑端悬停：黑块从左往右滑出 */
	@media (hover: hover) and (pointer: fine) {
		.view-all-link:hover {
			color: #ffffff !important;   
		}
		.view-all-link:hover::before {
			transform: scaleX(1);
		}
	}

	/* 手机端触摸优化：无多余动效，防闪黑 */
	@media (hover: none) or (pointer: coarse) {
		.view-all-link::before {
			display: none !important;
		}
		.view-all-link:active {
			background-color: #111111 !important;
			color: #ffffff !important;
		}
	}

	/* ==========================================================================
	   博客卡片网格与卡片标题布局
	   ========================================================================== */
	.blog-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax((320/16rem), 1fr));
		gap: (30/16rem);
	}

	.blog-card {
		display: flex;
		flex-direction: column;
		background: #ffffff;
		
		.image-wrapper {
			width: 100%;
			aspect-ratio: 16 / 9;
			overflow: hidden;
			border-radius: 12px;
			margin-bottom: (16/16rem);
			
			img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				transition: transform 0.3s ease;
			}
		}
		
		&:hover .image-wrapper img {
			transform: scale(1.05);
		}
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: (12/16rem);
		margin-bottom: (8/16rem);
		font-size: (14/16rem);
		color: #666666;
		
		.category-badge {
			background-color: #f3f4f6;
			padding: (4/16rem) (8/16rem);
			border-radius: 4px;
			font-weight: 600;
		}
	}

	.card-title {
		display: -webkit-box !important;
		-webkit-line-clamp: 1 !important;
		-webkit-box-orient: vertical !important;
		overflow: hidden !important;
		font-size: (20/16rem);         
		font-weight: 700;
		margin: (10/16rem) 0;
		line-height: 1.4;
		
		a {
			display: inline !important;
			color: #111111;
			text-decoration: none;
			&:hover {
				color: #9dc815;
			}
		}
	}

	.card-description {
		font-size: (16/16rem);
		line-height: 1.5;
		color: #666666;
		margin: 0 0 (16/16rem) 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* ==========================================================================
	   🌟 修复：READ MORE 按钮（找回方框与按钮边框样式）
	   ========================================================================== */
	.read-more-btn {
		font-size: (14/16rem);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: #111111;
		text-decoration: none;
		margin-top: auto;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		align-self: flex-start; /* 让按钮保持包裹自身文字的宽度 */
		
		/* 找回方框及线条样式 */
		padding: (10/16rem) (20/16rem);
		border: 2px solid #111111;
		border-radius: 4px;
		background-color: transparent;
		
		transition: all 0.3s ease;
		
		&:hover {
			background-color: #111111;
			color: #ffffff;
		}
	}

	/* ==========================================================================
	   暗黑模式暗流适配
	   ========================================================================== */
	body.dark-mode {
		#recent-blog {
			background-color: #111111;
			.header-left h2, .sub-title, .header-right p, .card-title a {
				color: #ffffff;
			}
			.section-divider {
				background-color: #333333;
			}
			.card-meta .category-badge {
				background-color: #222222;
				color: #aaaaaa;
			}
			.read-more-btn {
				color: #ffffff;
				border-color: #ffffff;
				&:hover {
					background-color: #ffffff;
					color: #111111;
				}
			}
		}
	}
</style>