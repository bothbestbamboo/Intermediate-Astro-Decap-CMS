---
/**
 * * This page generates the individual product detail pages based on the products collection
 **/

import { getCollection, render } from "astro:content";
import BlogPostLayout from "@layouts/BlogPostLayout.astro";

export async function getStaticPaths() {
	const products = await getCollection("products");
	return products.map((entry) => ({
		params: { product: entry.id },
		props: { product: entry },
	}));
}

const { product } = Astro.props;

// 🔽 筑起全方位防御：把所有可能被当做图片描述的字段全填上
const safeAltText = product.data.imageAlt || product.data.title || "Bothbest Bamboo Product";

const formattedProduct = {
	...product,
	data: {
		...product.data,
		author: "Bothbest", // 顺手补齐原博客要求的作者字段
		image: product.data.image,
		imageAlt: safeAltText, // 兼容底层组件
		alt: safeAltText,      // 兼顾某些特定 Image 标签
		title: product.data.title,
		tags: product.data.tags || ["Products"], // 传递给布局用来判断并注入询盘框
	}
};

const { headings } = await render(product);
---

<BlogPostLayout post={formattedProduct} headings={headings} />