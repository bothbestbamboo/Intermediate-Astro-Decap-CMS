{
  "name": "intermediate-astro-decap-cms-starter-kit",
  "type": "module",
  "version": "4.0.0",
  "description": "An Astro v7 starter kit with five pre-built pages, a Decap CMS blog, LESS preprocessing, dark mode, SEO (Open Graph, JSON-LD, sitemap), Astro image optimization, and View Transitions. While this starter kit was built for CodeStitch users and agency owners in mind, it can be used with your OWN HTML and CSS. ",
  "repository": {
    "type": "git",
    "url": "https://github.com/CodeStitchOfficial/Intermediate-Astro-Decap-CMS"
  },
  "homepage": "https://intermediate-astro-kit-decap-cms.netlify.app",
  "keywords": [
    "withastro",
    "astro-theme",
    "starter",
    "starter-kit",
    "blog",
    "cms",
    "decap-cms",
    "netlify",
    "view-transitions",
    "css",
    "ui",
    "image",
    "seo",
    "performance"
  ],
  "scripts": {
    "astro": "astro dev",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "npm run build && wrangler dev",
    "remove-decap": "node scripts/remove-decap.js",
    "remove-demo": "node scripts/remove-demo.js",
    "remove-dark-mode": "node scripts/remove-dark-mode.js",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.0",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.5",
    "astro-icon": "^1.1.5",
    "autoprefixer": "^10.5.2",
    "less": "^4.6.7"
  },
  "devDependencies": {
    "netlify-plugin-cache": "^1.0.3",
    "wrangler": "^4.106.0"
  }
