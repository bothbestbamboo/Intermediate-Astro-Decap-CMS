---
// Utils
import { getImage } from "astro:assets";

// Components
import BaseLayout from "@layouts/BaseLayout.astro";
import Banner from "@components/Banner/Banner.astro";
import ReviewsSection from "@components/Reviews/Reviews.astro";
import CTA from "@components/CTA/CTASimple.astro";

// Images
import landingImage from "@assets/images/gallery/bannerreview.jpg";
const optimizedImage = await getImage({ src: landingImage, format: "webp" });
---

<BaseLayout title="Reviews" description="Customers reviews for Bothbest Bamboo Flooring, Bothbest is a professional manufacturer and exporter of bamboo panels, bamboo veneer, and bamboo flooring in China" heroImage={optimizedImage}>
    <Banner 
        title="Reviews" 
        subtitle="See why global wholesalers, contractors, and architects trust Bothbest for factory-direct bamboo solutions and exceptional product quality." 
        image={optimizedImage} 
    />
    <ReviewsSection />
    <CTA />
</BaseLayout>
