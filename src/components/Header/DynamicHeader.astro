---
/**
 * * DYNAMIC HEADER COMPONENT
 * * =======================
 * * 修复了 Icon 缺失引起的打包错误
 * * 升级为扁平化、分列式产品大导航菜单（Mega Menu）
 **/

import { Icon } from "astro-icon/components";
import DarkModeToggle from "@components/DarkModeToggle/DarkModeToggle.astro";
---

<header id="cs-navigation">
	<div class="cs-container">
		<!--Nav Logo-->
		<a
			href="/"
			class="cs-logo"
			aria-label="Return to Home page"
		>
			<Icon name="logo-black" />
		</a>
		<!--Navigation List-->
		<nav class="cs-nav" aria-label="main navigation">
			<!--Mobile Nav Toggle-->
			<button
				class="cs-toggle"
				id="cs-toggle"
				aria-expanded="false"
				aria-controls="cs-ul-wrapper"
				aria-haspopup="menu"
				aria-label="mobile menu toggle"
			>
				<span class="cs-box" aria-hidden="true">
					<span class="cs-line cs-line1" aria-hidden="true"></span>
					<span class="cs-line cs-line2" aria-hidden="true"></span>
					<span class="cs-line cs-line3" aria-hidden="true"></span>
				</span>
			</button>
			
			<div class="cs-ul-wrapper" id="cs-ul-wrapper">
				<ul id="cs-expanded" class="cs-ul">
					<!-- Home -->
					<li class="cs-li">
						<a
							href="/"
							class:list={[
								"cs-li-link",
								{ "cs-active": Astro.url.pathname === "/" },
							]}
							aria-current={Astro.url.pathname === "/" ? "page" : undefined}
						>
							Home
						</a>
					</li>
					<!-- About Us -->
					<li class="cs-li">
						<a
							href="/about/"
							class:list={[
								"cs-li-link",
								{ "cs-active": Astro.url.pathname === "/about/" },
							]}
							aria-current={Astro.url.pathname === "/about/" ? "page" : undefined}
						>
							About Us
						</a>
					</li>

					<!-- 🎯 1. Products 扁平化多列大菜单 (Mega Menu) -->
					<li class="cs-li cs-dropdown cs-mega-dropdown">
						<button
							class:list={[
								"cs-li-link cs-dropdown-toggle",
								{ "cs-active": Astro.url.pathname.includes("/products/") },
							]}
							aria-haspopup="menu"
							aria-expanded="false"
							id="products-dropdown-toggle"
						>
							Products
							<Icon name="mdi--caret" class="cs-drop-icon" />
						</button>
						
						<!-- 电脑端横向分 3 列，手机端垂直向下展开 -->
						<div class="cs-drop-ul cs-mega-wrapper">
							<!-- 第一列：Bamboo Flooring -->
							<div class="cs-mega-column">
								<span class="cs-mega-title">Bamboo Flooring</span>
								<ul class="cs-mega-child-ul">
									<li class="cs-drop-li"><a href="/products/flooring/" class="cs-li-link cs-drop-link">View All Flooring</a></li>
									<li class="cs-drop-li"><a href="/products/solid-horizontal-natural/" class="cs-li-link cs-drop-link">Horizontal Natural</a></li>
									<li class="cs-drop-li"><a href="/products/solid-vertical-carbonized/" class="cs-li-link cs-drop-link">Vertical Carbonized</a></li>
									<li class="cs-drop-li"><a href="/products/strand-woven-carbonized/" class="cs-li-link cs-drop-link">Strand Woven Carbonized</a></li>
								</ul>
							</div>
							<!-- 第二列：Bamboo Decking -->
							<div class="cs-mega-column">
								<span class="cs-mega-title">Bamboo Decking</span>
								<ul class="cs-mega-child-ul">
									<li class="cs-drop-li"><a href="/products/decking/" class="cs-li-link cs-drop-link">View All Decking</a></li>
									<li class="cs-drop-li"><a href="/products/symmetrical-grooved/" class="cs-li-link cs-drop-link">Symmetrical Grooved</a></li>
									<li class="cs-drop-li"><a href="/products/deep-carbonized/" class="cs-li-link cs-drop-link">Deep Carbonized</a></li>
									<li class="cs-drop-li"><a href="/products/hidden-fastener/" class="cs-li-link cs-drop-link">Hidden Fastener</a></li>
								</ul>
							</div>
							<!-- 第三列：Bamboo Plywood -->
							<div class="cs-mega-column">
								<span class="cs-mega-title">Bamboo Plywood</span>
								<ul class="cs-mega-child-ul">
									<li class="cs-drop-li"><a href="/products/plywood/" class="cs-li-link cs-drop-link">View All Plywood</a></li>
									<li class="cs-drop-li"><a href="/products/single-layer-panel/" class="cs-li-link cs-drop-link">Single-Layer Panel</a></li>
									<li class="cs-drop-li"><a href="/products/cross-ply-panels/" class="cs-li-link cs-drop-link">Cross-Ply Panels</a></li>
									<li class="cs-drop-li"><a href="/products/vertical-grain/" class="cs-li-link cs-drop-link">Vertical Grain</a></li>
								</ul>
							</div>
						</div>
					</li>

					<!-- 🛠️ 2. Projects 下拉菜单 -->
					<li class="cs-li cs-dropdown">
						<button
							class:list={[
								"cs-li-link cs-dropdown-toggle",
								{ "cs-active": Astro.url.pathname.includes("/projects/") },
							]}
							aria-haspopup="menu"
							aria-expanded="false"
							id="projects-dropdown-toggle"
						>
							Projects
							<Icon name="mdi--caret" class="cs-drop-icon" />
						</button>
						<ul class="cs-drop-ul" aria-labelledby="projects-dropdown-toggle">
							<li class="cs-drop-li">
								<a
									href="/projects/bamboo-flooring/"
									class="cs-li-link cs-drop-link"
									aria-current={Astro.url.pathname === "/projects/bamboo-flooring/" ? "page" : undefined}
								>Bamboo Flooring</a>
							</li>
							<li class="cs-drop-li">
								<a
									href="/projects/bamboo-decking/"
									class="cs-li-link cs-drop-link"
									aria-current={Astro.url.pathname === "/projects/bamboo-decking/" ? "page" : undefined}
								>Bamboo Decking</a>
							</li>
							<li class="cs-drop-li">
								<a
									href="/projects/bamboo-plywood/"
									class="cs-li-link cs-drop-link"
									aria-current={Astro.url.pathname === "/projects/bamboo-plywood/" ? "page" : undefined}
								>Bamboo Plywood</a>
							</li>
						</ul>
					</li>

					<!-- Blog -->
					<li class="cs-li">
						<a
							href="/blog/"
							class:list={[
								"cs-li-link",
								{ "cs-active": Astro.url.pathname === "/blog/" },
							]}
							aria-current={Astro.url.pathname === "/blog/" ? "page" : undefined}
						>
							Blog
						</a>
					</li>
					<!-- Contact (Mobile Only) -->
					<li class="cs-li cs-hide-on-desktop">
						<a
							href="/contact/"
							class:list={[
								"cs-li-link",
								{ "cs-active": Astro.url.pathname === "/contact/" },
							]}
							aria-current={Astro.url.pathname === "/contact/" ? "page" : undefined}
						>
							Contact
						</a>
					</li>
				</ul>
			</div>
		</nav>
		<a href="/contact/" class="cs-button-solid cs-nav-button">Contact Us</a>
		<DarkModeToggle />
	</div>
</header>

<style lang="less">
	/*-- -------------------------- -->
<---     Mobile Navigation      -->
<--- -------------------------- -*/

	/* Mobile - 1023px */
	@media only screen and (max-width: 63.9375rem) {
		body {
			&.cs-open {
				overflow: hidden;
			}
		}

		#cs-navigation {
			width: 100%;
			box-sizing: border-box;
			padding: (12/16rem) (16/16rem);
			background-color: #fff;
			box-shadow: rgba(149, 157, 165, 0.2) 0px 8px 24px;
			position: fixed;
			z-index: 10000;

			&:before {
				content: "";
				width: 0%;
				height: 100vh;
				background: rgba(0, 0, 0, 0.6);
				opacity: 0;
				display: block;
				position: absolute;
				top: 100%;
				right: 0;
				z-index: -11;
				transition: width 0.5s, opacity 0.3s;
				-webkit-backdrop-filter: blur(10px);
				backdrop-filter: blur(10px);
			}

			&.cs-active {
				&:before {
					width: 100%;
					opacity: 1;
				}

				.cs-ul-wrapper {
					opacity: 1;
					visibility: visible;
					transform: scaleX(1);
					transition-delay: 0.2s;
				}

				.cs-li {
					opacity: 1;
					transform: translateX(0);
				}
			}

			.cs-container {
				width: 100%;
				display: flex;
				justify-content: flex-end;
				align-items: center;
			}

			.cs-logo {
				width: 40%;
				max-width: (146/16rem);
				height: 100%;
				margin: 0 auto 0 0;
				box-sizing: border-box;
				padding: 0;
				display: flex;
				justify-content: center;
				align-items: center;
				z-index: 10;

				svg {
					width: 100%;
					height: 100%;
					object-fit: contain;
					object-position: left;
				}
			}

			.cs-toggle {
				width: clamp(2.75rem, 6vw, 3rem);
				height: clamp(2.75rem, 6vw, 3rem);
				margin: 0 0 0 auto;
				background-color: transparent;
				border: none;
				border-radius: (4/16rem);
				display: flex;
				justify-content: center;
				align-items: center;
			}

			.cs-active {
				.cs-line1 {
					top: 50%;
					transform: translate(-50%, -50%) rotate(225deg);
				}

				.cs-line2 {
					top: 50%;
					transform: translate(-50%, -50%) translateY(0) rotate(-225deg);
					transform-origin: center;
				}

				.cs-line3 {
					opacity: 0;
					bottom: 100%;
				}
			}

			.cs-box {
				width: clamp(1.5rem, 2vw, 1.75rem);
				height: clamp(0.875rem, 1.5vw, 1rem);
				position: relative;
			}

			.cs-line {
				width: 100%;
				height: 2px;
				background-color: #1a1a1a;
				border-radius: 2px;
				position: absolute;
				left: 50%;
				transform: translateX(-50%);
			}

			.cs-line1 {
				top: 0;
				transition: transform 0.5s, top 0.3s, left 0.3s;
				animation-duration: 0.7s;
				animation-timing-function: ease;
				animation-direction: normal;
				animation-fill-mode: forwards;
				transform-origin: center;
			}

			.cs-line2 {
				top: 50%;
				transform: translateX(-50%) translateY(-50%);
				transition: top 0.3s, left 0.3s, transform 0.5s;
				animation-duration: 0.7s;
				animation-timing-function: ease;
				animation-direction: normal;
				animation-fill-mode: forwards;
			}

			.cs-line3 {
				bottom: 0;
				transition: bottom 0.3s, opacity 0.3s;
			}

			.cs-ul-wrapper {
				height: 100vh;
				background-color: #fff;
				box-shadow: inset rgba(0, 0, 0, 0.2) 0px 8px 24px;
				opacity: 0;
				visibility: hidden;
				position: absolute;
				top: 100%;
				right: 0;
				left: auto;
				z-index: -1;
				overflow: hidden;
				transform: scaleX(0);
				transition: transform 0.4s, opacity 0.3s;
				transform-origin: top right;
			}

			.cs-ul {
				width: auto;
				min-width: 40%;
				height: 65vh;
				margin: 0;
				padding: (48/16rem) clamp(1.75rem, 3vw, 2.5rem) (32/16rem) (70/16rem);
				display: flex;
				flex-direction: column;
				justify-content: flex-start;
				align-items: flex-end;
				gap: (20/16rem);
				overflow: scroll;
			}

			.cs-li {
				text-align: right;
				list-style: none;
				width: 100%;
				margin-right: 0;
				opacity: 0;
				transform: translateX(-40/16rem);
				transition: transform 0.6s, opacity 0.9s;

				&:nth-of-type(1) { transition-delay: 0.05s; }
				&:nth-of-type(2) { transition-delay: 0.1s; }
				&:nth-of-type(3) { transition-delay: 0.15s; }
				&:nth-of-type(4) { transition-delay: 0.2s; }
				&:nth-of-type(5) { transition-delay: 0.25s; }
				&:nth-of-type(6) { transition-delay: 0.3s; }
				&:nth-of-type(7) { transition-delay: 0.35s; }
			}

			.cs-li-link {
				font-size: clamp(1rem, 2.5vw, 1.5rem);
				color: inherit;
				line-height: 1.2em;
				text-decoration: none;
				margin: 0;
				display: inline-block;
				position: relative;

				&:before {
					content: "";
					width: 100%;
					height: 1px;
					background: currentColor;
					opacity: 1;
					display: none;
					position: absolute;
					bottom: (-2/16rem);
					left: 0;
				}

				&.cs-active {
					&:before {
						display: block;
					}
				}
			}

			.cs-button-solid {
				display: none;
			}
		}
	}

	/* Dark Mode Mobile */
	@media only screen and (max-width: 63.9375rem) {
		body.dark-mode {
			#cs-navigation {
				background-color: var(--dark);
				.cs-logo { filter: grayscale(1) brightness(1000%); }
				.cs-line { background-color: #fff; }
				.cs-ul-wrapper { background-color: var(--medium); }
				.cs-li-link { color: var(--bodyTextColorWhite); }
			}
		}
	}

	/*-- -------------------------- -->
	<---     Navigation Dropdown    -->
	<--- -------------------------- -*/

	/* Mobile - 1023px */
	@media only screen and (max-width: 63.9375rem) {
		#cs-navigation {
			.cs-dropdown {
				color: var(--headerColor);
				position: relative;

				&.cs-active {
					.cs-drop-ul {
						height: auto;
						margin: (12/16rem) 0 0 0;
						padding: (16/16rem);
						opacity: 1;
						visibility: visible;
						transform: scale(1);
					}
					.cs-drop-link { opacity: 1; }
					.cs-drop-icon { transform: rotate(0); }
				}
			}

			.cs-drop-icon {
				width: (15/16rem);
				height: auto;
				display: inline-block;
				color: inherit;
				transform: rotate(180deg);
				transition: 0.3s;
			}

			/* 手机端大菜单折叠形态适配 */
			.cs-mega-wrapper {
				display: flex;
				flex-direction: column;
				gap: (20/16rem);
			}
			.cs-mega-title {
				display: block;
				font-size: (14/16rem);
				font-weight: 800;
				text-transform: uppercase;
				color: #fff;
				margin-bottom: (8/16rem);
				border-bottom: 1px solid rgba(255,255,255,0.2);
				padding-bottom: 4px;
			}
			.cs-mega-child-ul {
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: (10/16rem);
				align-items: flex-end;
			}

			.cs-drop-ul {
				width: 100%;
				height: 0;
				margin: 0;
				box-sizing: border-box;
				padding: 0 (24/16rem);
				background-color: var(--primary);
				opacity: 0;
				display: flex;
				visibility: hidden;
				flex-direction: column;
				justify-content: flex-start;
				align-items: flex-end;
				gap: (12/16rem);
				overflow: hidden;
				transform: scale(0);
				transition: padding 0.3s, margin 0.3s, height 0.3s, opacity 0.3s, transform 0.3s, visibility 0.3s;
				transform-origin: top right;
			}

			.cs-drop-li {
				text-align: inherit;
				list-style: none;
			}

			.cs-li-link {
				&.cs-drop-link {
					font-size: clamp(0.875rem, 2vw, 1.25rem);
					color: #fff;
				}
			}

			.cs-dropdown-toggle {
				background-color: transparent;
				border: none;
				appearance: none;
			}
		}
	}

	/* Desktop - 1024px */
	@media only screen and (min-width: 64rem) {
		#cs-navigation {
			.cs-dropdown {
				position: relative;
				&:hover,
				&.cs-active {
					cursor: pointer;
					.cs-drop-ul {
						opacity: 1;
						visibility: visible;
						transform: scaleY(1);
					}
					.cs-drop-li {
						opacity: 1;
						transform: translateY(0);
					}
				}
			}

			.cs-dropdown:has(.cs-drop-icon) {
				display: flex;
				align-items: center;
				&:hover {
					.cs-drop-icon { transform: rotate(0); }
				}
			}

			.cs-drop-icon {
				width: (15/16rem);
				height: auto;
				display: inline-block;
				color: inherit;
				transform: rotate(180deg);
				transition: 0.3s;
			}

			/* 🌟 标准的单列式下拉菜单样式 (用于 Projects) */
			ul.cs-drop-ul {
				min-width: (220/16rem);
				position: absolute;
				top: 100%;
				left: 0;
			}

			.cs-drop-ul {
				margin: 0;
				padding: (12/16rem) 0;
				background-color: #fff;
				box-shadow: rgba(149, 157, 165, 0.15) 0px 10px 30px;
				opacity: 0;
				border-bottom: 5px solid var(--primary);
				visibility: hidden;
				z-index: -100;
				overflow: hidden;
				transform: scaleY(0);
				transition: transform 0.3s, visibility 0.3s, opacity 0.3s;
				transform-origin: top;
			}

			/* 🌟 核心升级：电脑端大菜单 (Mega Menu 3列布局) */
			.cs-mega-dropdown {
				/* 保持基准线在 navigation 容器内进行超宽绝对定位 */
				position: static !important; 
			}

			.cs-mega-wrapper {
				width: 100%;
				max-width: (1100/16rem); /* 完美适配宽屏视觉宽度 */
				left: 50% !important;
				transform: translateX(-50%) scaleY(0) !important;
				position: absolute;
				top: 100%;
				box-sizing: border-box;
				padding: (32/16rem) !important;
				display: grid !important;
				grid-template-columns: repeat(3, 1fr) !important; /* 严格横向分成 3 列 */
				gap: (40/16rem) !important;
			}

			&:hover .cs-mega-wrapper,
			.cs-mega-dropdown.cs-active .cs-mega-wrapper {
				transform: translateX(-50%) scaleY(1) !important;
			}

			.cs-mega-column {
				display: flex;
				flex-direction: column;
			</div>

			.cs-mega-title {
				font-size: (14/16rem);
				font-weight: 800;
				text-transform: uppercase;
				color: var(--headerColor);
				letter-spacing: 0.05em;
				margin-bottom: (16/16rem);
				padding-bottom: (8/16rem);
				border-bottom: 2px solid #f3f4f6; /* 清爽的分栏底线 */
				display: block;
			}

			.cs-mega-child-ul {
				padding: 0;
				margin: 0;
				list-style: none;
				display: flex;
				flex-direction: column;
				gap: (4/16rem);
			}

			.cs-drop-li {
				font-size: (15/16rem);
				list-style: none;
				width: 100%;
				height: auto;
				opacity: 0;
				display: block;
				transform: translateY(-10/16rem);
				transition: opacity 0.4s, transform 0.4s;

				&:nth-of-type(1) { transition-delay: 0.03s; }
				&:nth-of-type(2) { transition-delay: 0.06s; }
				&:nth-of-type(3) { transition-delay: 0.09s; }
				&:nth-of-type(4) { transition-delay: 0.12s; }
			}

			.cs-li-link {
				&.cs-drop-link {
					font-size: (15/16rem);
					line-height: 1.4em;
					text-decoration: none;
					white-space: nowrap;
					width: 100%;
					box-sizing: border-box;
					padding: (8/16rem) (12/16rem);
					color: var(--bodyTextColor);
					display: block;
					border-radius: 4px;
					transition: color 0.2s, background-color 0.2s;

					&:hover {
						background-color: #f4f4f5;
						color: var(--primary) !important;
					}
					&:before { display: none; }
				}
			}

			.cs-dropdown-toggle {
				background-color: transparent;
				border: none;
				appearance: none;
			}
		}
	}

	/* Dark Mode Desktop */
	@media only screen and (min-width: 64rem) {
		body.dark-mode {
			#cs-navigation {
				.cs-drop-ul {
					background-color: var(--dark);
					border-bottom-color: var(--primaryLight);
				}
				.cs-mega-title {
					color: #ffffff;
					border-bottom-color: #222;
				}
				.cs-li-link.cs-drop-link {
					color: var(--bodyTextColorWhite);
					&:hover {
						background-color: var(--medium);
						color: var(--primaryLight) !important;
					}
				}
				.cs-drop-icon { filter: grayscale(1) brightness(1000%); }
			}
		}
	}

	/*-- -------------------------- -->
	<---     Desktop Navigation     -->
	<--- -------------------------- -*/

	/* Small Desktop - 1024px */
	@media only screen and (min-width: 64rem) {
		#cs-navigation {
			width: 100%;
			box-sizing: border-box;
			padding: 0 (16/16rem);
			background-color: #fff;
			box-shadow: rgba(149, 157, 165, 0.1) 0px 8px 24px;
			position: fixed;
			z-index: 10000;

			.cs-container {
				width: 100%;
				max-width: (1280/16rem);
				margin: auto;
				display: flex;
				justify-content: flex-end;
				align-items: center;
				gap: (24/16rem);
			}

			.cs-toggle { display: none; }

