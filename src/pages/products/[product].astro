---
import { getCollection, render } from "astro:content";
import BlogPostLayout from "@layouts/BlogPostLayout.astro";

export async function getStaticPaths() {
	const products = await getCollection("products");
	return products.map((entry) => ({
		params: { product: entry.id },
		props: { product: entry },
	}));
}

const { product } = Astro.props;

const safeAltText = product.data.imageAlt || product.data.title || "Bothbest Bamboo Product";

// 1. 获取所有产品，用来做底部的相关产品推荐
const allProducts = await getCollection("products");
const currentTags = product.data.tags || [];
const relatedProducts = allProducts
	.filter((item) => {
		const hasCommonTag = item.data.tags?.some(tag => currentTags.includes(tag));
		return hasCommonTag && item.id !== product.id;
	})
	.slice(0, 3);

const { Content, headings } = await render(product);

// 2. 🌟 核心突破：既然外面不渲染，我们将所有新组装的 HTML 作为一个整体数据传给底层布局
const formattedProduct = {
	...product,
	data: {
		...product.data,
		author: "Bothbest", 
		image: product.data.image,
		imageAlt: safeAltText, 
		alt: safeAltText,      
		title: product.data.title,
		tags: product.data.tags || ["Products"], 
	}
};
---

<BlogPostLayout post={formattedProduct} headings={headings}>
	
	<!-- 🌟 把双栏和底部代码牢牢包裹在 Layout 标签内部 -->
	<div class="product-layout-wrapper">
		
		<div class="product-detail-container">
			<!-- 左栏：产品 Markdown 核心正文 -->
			<div class="product-main-content">
				<Content />
			</div>

			<!-- 右栏：商务互动边栏 -->
			<aside class="product-sidebar">
				<!-- 询盘定位 -->
				<div class="sidebar-card inquiry-card">
					<h3>Interested in this Product?</h3>
					<p>Get instant factory-direct pricing, custom specifications, and material samples for your projects.</p>
					<a href="/contact/#cs-form" class="sidebar-inquiry-btn">
						Inquire Now ➔
					</a>
				</div>

				<!-- 标签/分类 -->
				{product.data.tags && product.data.tags.length > 0 && (
					<div class="sidebar-card tags-card">
						<h4>Product Categories</h4>
						<div class="sidebar-tags-list">
							{product.data.tags.map((tag) => (
								<span class="sidebar-tag-item">{tag}</span>
							))}
						</div>
					</div>
				)}
			</aside>
		</div>

		<!-- 下方：相关产品推荐区域 -->
		{relatedProducts.length > 0 && (
			<div class="related-products-section">
				<hr class="related-divider" />
				<h3 class="related-section-title">Related Bamboo Products</h3>
				<div class="related-grid">
					{relatedProducts.map((item) => {
						const itemImage = item.data.image 
							? (typeof item.data.image === 'object' ? item.data.image.src : item.data.image)
							: "/assets/images/default-product.jpg";
						return (
							<div class="related-card">
								<a href={`/products/${item.id}/`} class="img-link">
									<img src={itemImage} alt={item.data.title} loading="lazy" />
								</a>
								<div class="related-info">
									<h4><a href={`/products/${item.id}/`}>{item.data.title}</a></h4>
									<a href={`/products/${item.id}/`} class="view-detail-link">View Details ↗</a>
								</div>
							</div>
						);
					})}
				</div>
			</div>
		)}

	</div>

</BlogPostLayout>

<style lang="less" is:global>
	/* 🌟 注意：这里使用了 is:global 确保样式能强行渗透进 BlogPostLayout 内部组件 */
	.product-layout-wrapper {
		width: 100%;
		margin-top: 30px;
	}

	.product-detail-container {
		display: flex;
		gap: 40px;
		align-items: flex-start;
		margin-bottom: 60px;
		width: 100%;
		
		@media (max-width: 991px) {
			flex-direction: column;
		}
	}

	.product-main-content {
		flex: 1;
		min-width: 0;
		p {
			font-size: 16px;
			line-height: 1.6;
			color: #333333;
			margin-bottom: 20px;
		}
	}

	.product-sidebar {
		width: 320px;
		position: sticky;
		top: 100px;
		flex-shrink: 0;

		@media (max-width: 991px) {
			width: 100%;
			position: static;
		}

		.sidebar-card {
			background: #f9fafb;
			border: 1px solid #e5e7eb;
			border-radius: 8px;
			padding: 24px;
			margin-bottom: 24px;
		}

		.inquiry-card {
			border-left: 4px solid #a3e635;
			h3 {
				font-size: 18px;
				font-weight: 700;
				color: #111111;
				margin: 0 0 12px 0;
			}
			p {
				font-size: 14px;
				line-height: 1.5;
				color: #666666;
				margin: 0 0 20px 0;
			}
			.sidebar-inquiry-btn {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 100%;
				padding: 12px;
				background-color: #111111;
				color: #ffffff !important;
				font-size: 14px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				text-decoration: none;
				border-radius: 4px;
				transition: all 0.3s ease;
				&:hover {
					background-color: #a3e635;
					color: #111111 !important;
				}
			}
		}

		.tags-card {
			h4 {
				font-size: 16px;
				font-weight: 700;
				color: #111111;
				margin: 0 0 16px 0;
				text-transform: uppercase;
				letter-spacing: 0.05em;
			}
			.sidebar-tags-list {
				display: flex;
				flex-wrap: wrap;
				gap: 8px;
			}
			.sidebar-tag-item {
				font-size: 13px;
				font-weight: 600;
				background-color: #ffffff;
				border: 1px solid #e5e7eb;
				color: #4a4a4a;
				padding: 6px 12px;
				border-radius: 4px;
			}
		}
	}

	.related-products-section {
		margin-top: 60px;
		.related-divider {
			border: 0;
			height: 1px;
			background-color: #e5e7eb;
			margin-bottom: 40px;
		}
		.related-section-title {
			font-size: 24px;
			font-weight: 800;
			color: #111111;
			margin: 0 0 24px 0;
		}
		.related-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
			gap: 24px;
		}
		.related-card {
			background: #ffffff;
			border: 1px solid #e5e7eb;
			border-radius: 8px;
			overflow: hidden;
			display: flex;
			flex-direction: column;
			transition: transform 0.3s ease, box-shadow 0.3s ease;
			&:hover {
				transform: translateY(-4px);
				box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05);
			}
			.img-link {
				width: 100%;
				aspect-ratio: 4 / 3;
				overflow: hidden;
				display: block;
				img {
					width: 100%;
					height: 100%;
					object-fit: cover;
					transition: transform 0.3s ease;
				}
			}
			&:hover .img-link img { transform: scale(1.05); }
			.related-info {
				padding: 16px;
				display: flex;
				flex-direction: column;
				flex: 1;
				h4 {
					font-size: 16px;
					font-weight: 700;
					margin: 0 0 12px 0;
					line-height: 1.4;
					a {
						color: #111111;
						text-decoration: none;
						&:hover { color: #a3e635; }
					}
				}
				.view-detail-link {
					font-size: 14px;
					font-weight: 600;
					color: #666666;
					text-decoration: none;
					margin-top: auto;
					&:hover { color: #a3e635; }
				}
			}
		}
	}

	/* 暗黑模式 */
	body.dark-mode {
		.product-main-content p { color: #cccccc; }
		.product-sidebar {
			.sidebar-card { background: #1a1a1a; border-color: #333333; }
			.inquiry-card h3, .tags-card h4 { color: #ffffff; }
			.inquiry-card p { color: #999999; }
			.tags-card .sidebar-tag-item { background-color: #262626; border-color: #404040; color: #cccccc; }
		}
		.related-products-section {
			.related-divider { background-color: #333333; }
			.related-section-title { color: #ffffff; }
			.related-card {
				background: #111111; border-color: #333333;
				.related-info h4 a { color: #ffffff; }
				.related-info .view-detail-link { color: #999999; }
			}
		}
	}
</style>