---
/**
 * * This page generates the individual product detail pages based on the products collection
 **/

import { getCollection, render } from "astro:content";
import BlogPostLayout from "@layouts/BlogPostLayout.astro";

export async function getStaticPaths() {
	const products = await getCollection("products");
	return products.map((entry) => ({
		params: { product: entry.id },
		props: { product: entry },
	}));
}

const { product } = Astro.props;

// 🔽 筑起全方位无死角防御：把所有可能被当做图片描述的字段全填上
const safeAltText = product.data.imageAlt || product.data.title || "Bothbest Bamboo Product";

const formattedProduct = {
	...product,
	data: {
		...product.data,
		author: "Bothbest", // 顺手补齐原博客要求的作者字段
		image: product.data.image,
		imageAlt: safeAltText, // 兼容底层组件
		alt: safeAltText,      // 兼顾某些特定 Image 标签
		title: product.data.title,
		tags: product.data.tags || ["Products"], 
	}
};

const { Content, headings } = await render(product);
---

<BlogPostLayout post={formattedProduct} headings={headings}>
	<!-- 🌟 原汁原味的产品正文内容 -->
	<Content />

	<!-- 🌟 在线询盘模块的 HTML 源码（暂时隐藏，交由下方脚本安全植入右侧边栏） -->
	<div id="product-sidebar-inquiry-source" style="display: none;">
		<div class="product-inquiry-box">
			<h3>Interested in this Product?</h3>
			<p>Get instant factory-direct pricing, custom specifications, and material samples for your projects.</p>
			<a href="/contact/#cs-form" class="product-inquiry-btn">
				INQUIRE NOW ➔
			</a>
		</div>
	</div>
</BlogPostLayout>

<!-- 🌟 纯原生无感传送脚本：把询盘组件极其稳定地塞到右侧 Table of Contents 的下方，绝不搞乱双栏 -->
<script is:inline>
	function injectInquiryBox() {
		// 检查是否已经注入过，避免多发重叠
		if (document.querySelector('.product-inquiry-box-inserted')) return;

		const source = document.getElementById('product-sidebar-inquiry-source');
		const desktopTOC = document.getElementById('desktop-toc'); // 原博客右侧目录的 ID

		if (source && desktopTOC) {
			const wrapper = document.createElement('div');
			wrapper.className = 'product-inquiry-box-inserted';
			wrapper.innerHTML = source.innerHTML;
			
			// 把询盘框塞到右侧目录组件的亲弟弟位置（紧随其后）
			desktopTOC.parentNode.insertBefore(wrapper, desktopTOC.nextSibling);
		}
	}

	// 兼容 Astro 的 SPA 路由加载模式
	document.addEventListener('astro:page-load', injectInquiryBox);
	// 兜底初次直接加载
	injectInquiryBox();
</script>

<style lang="less" is:global>
	/* ==========================================================================
	   精细还原并美化参考图 63ca5bad36c0d6841b57d72df79539b9.jpg 中的询盘外观
	   ========================================================================== */
	.product-inquiry-box-inserted {
		margin-top: 24px; /* 紧跟在 QUICK NAVIGATION 目录下方，间距适中 */
		width: 100%;
		box-sizing: border-box;

		.product-inquiry-box {
			background: #f9fafb;
			border: 1px solid #e5e7eb;
			border-radius: 8px;
			padding: 24px;
			border-left: 4px solid #a3e635; /* 复刻图中的高亮标志绿边缘线 */
			box-sizing: border-box;

			h3 {
				font-size: 16px;
				font-weight: 700;
				color: #111111;
				margin: 0 0 10px 0;
				font-family: inherit;
			}

			p {
				font-size: 13px;
				line-height: 1.5;
				color: #666666;
				margin: 0 0 18px 0;
			}

			.product-inquiry-btn {
				display: flex;
				align-items: center;
				justify-content: center;
				width: 100%;
				padding: 12px;
				background-color: #111111; /* 经典高转化纯黑按钮 */
				color: #ffffff !important;
				font-size: 12px;
				font-weight: 700;
				text-transform: uppercase;
				letter-spacing: 0.05em;
				text-decoration: none;
				border-radius: 4px;
				transition: background-color 0.3s ease;

				&:hover {
					background-color: #a3e635; /* 悬浮切换为工厂标志绿 */
					color: #111111 !important;
				}
			}
		}
	}

	/* 暗黑模式无缝调色 */
	body.dark-mode {
		.product-inquiry-box-inserted {
			.product-inquiry-box {
				background: #1a1a1a;
				border-color: #333333;
				h3 { color: #ffffff; }
				p { color: #999999; }
				.product-inquiry-btn {
					background-color: #f3f4f6;
					color: #111111 !important;
					&:hover { background-color: #a3e635; color: #111111 !important; }
				}
			}
		}
	}
</style>