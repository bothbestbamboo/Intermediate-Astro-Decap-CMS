---
// 🌟 彻底移除所有容易导致 Vercel 报错或路径丢失的 Icon 导入
---

<section id="services" class="services">
  <div class="card">
    <picture>
      <a href="https://api.iconify.design" rel="nofollow">
        <img 
          src="https://api.iconify.design/lucide:home.svg?color=%2385ea2d" 
          alt="Bamboo Flooring Icon" 
          width="40" 
          height="40"
          class="internal-service-img"
        />
      </a>
    </picture>
    <h2>Bamboo Flooring</h2>
    <p>
      Premium solid, engineered, and strand woven bamboo flooring designed for modern interiors. It delivers exceptional wear resistance, natural warmth, and eco-friendly elegance to any residential or commercial space.
    </p>
  </div>
  
  <div class="card">
    <picture>
      <a href="https://api.iconify.design" rel="nofollow">
        <img 
          src="https://api.iconify.design/lucide:sun.svg?color=%2385ea2d" 
          alt="Bamboo Decking Icon" 
          width="40" 
          height="40"
          class="internal-service-img"
        />
      </a>
    </picture>
    <h2>Bamboo Decking</h2>
    <p>
      High-density, exterior-grade bamboo decking engineered to withstand harsh outdoor elements. Featuring superior anti-corrosion, mold-resistance, it is perfect for luxury patios, gardens, and commercial walkways.
    </p>
  </div>
  
  <div class="card">
    <picture>
      <a href="https://api.iconify.design" rel="nofollow">
        <img 
          src="https://api.iconify.design/lucide:layers.svg?color=%2385ea2d" 
          alt="Bamboo Plywood Icon" 
          width="40" 
          height="40"
          class="internal-service-img"
        />
      </a>
    </picture>
    <h2>Bamboo Plywood</h2>
    <p>
      Multi-layer, high-strength architectural bamboo plywood. Ideal for high-end furniture manufacturing, tabletops, and interior design, offering a perfect sustainable alternative to traditional hardwood with superior structural integrity.
    </p>
  </div>
</section>

<style lang="less">
  /*-- -------------------------- -->
<---          Services          -->
<--- -------------------------- -*/

  /* ==========================================================================
     移动端优先基础样式 (Mobile 0em ~ 767px)
     ========================================================================== */
  @media only screen and (min-width: 0em) {
    .services {
      width: 90%;
      max-width: (1320/16em);
      margin: 0 auto;
      /* 🌟 核心修正：手机端彻底关闭往上的负边距！防止白色色块遮挡主图文字按钮 */
      margin-top: 20px !important; 
      margin-bottom: 40px;
      padding: 40px 20px;
      background: #ffffff;
      box-shadow: 0px 15px 35px rgba(0, 0, 0, 0.06);
      border-top: 6px solid var(--primary);
      border-radius: 8px;
      position: relative;
      z-index: 99;
      box-sizing: border-box;

      .card {
        width: 100%;
        max-width: 340px;
        margin: 0 auto 40px auto;
        display: flex;
        flex-direction: column;
        align-items: center; /* 强力居中 */
        box-sizing: border-box;

        &:last-of-type {
          margin-bottom: 0;
        }

        picture {
          width: 80px;
          height: 80px;
          margin: 0 auto 20px auto;
          background: var(--primary);
          border-radius: 50%;
          display: flex;
          justify-content: center;
          align-items: center;
          flex-shrink: 0;

          /* 🌟 赋予写死的内联 SVG 统一颜色与完美居中尺寸 */
          .internal-service-svg {
            width: 36px;
            height: 36px;
            color: #ffffff; /* 如果大底色是嫩绿，这里可以写#1a1a1a，若需要纯白则保留#ffffff */
          }
        }

        h2 {
          font-size: 24px; 
          font-weight: 700;
          line-height: 1.3; 
          text-align: center;
          margin: 0 0 12px 0;
          color: #1a1a1a;
          width: 100%;
        }

        p {
          font-size: 14px; 
          line-height: 1.5;
          text-align: center;
          width: 100%;
          opacity: 0.8;
          margin: 0;
          color: #4a4a4a;
        }
      }
    }
  }

  /* ==========================================================================
     平板端自适应布局 (Tablet 768px 及以上)
     ========================================================================== */
  @media only screen and (min-width: 768px) {
    .services {
      font-size: ~"min(1.8vw, 1em)";
      width: 96%;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      
      /* 🌟 只有在空间宽裕的大屏端，才允许往上提、形成盖在主图上的精美重叠层 */
      margin-top: (-140/16em) !important; 
      margin-bottom: (50/16em);

      .card {
        max-width: (325/16em);
        margin: 0;

        h2 {
          font-size: (28/16em); 
          line-height: 1.3;
        }
      }
    }
  }

  /* ==========================================================================
     宽屏电脑端样式 (Large Desktop 1300px 及以上)
     ========================================================================== */
  @media only screen and (min-width: 1300px) {
    .services {
      padding: (50/16em) (60/16em);
      margin-top: (-167/16em) !important; 

      .card {
        max-width: (357/16em);
        
        h2 {
          font-size: (32/16em);
        }
      }
    }
  }

  /* ==========================================================================
     暗黑模式完美兼容
     ========================================================================== */
  body.dark-mode {
    #services {
      background: var(--medium, #1a1a1a);

      picture {
        background: var(--primaryDark, #a3e635);
        .internal-service-svg {
          color: #111111;
        }
      }

      h2 {
        color: #ffffff;
      }
      p {
        color: #cccccc;
      }
    }
  }
</style>