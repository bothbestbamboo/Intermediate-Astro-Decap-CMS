---
// 1. 引入 Astro 原生内容集合方法
import { getCollection } from "astro:content";

// 2. 获取所有的博客文章，并按照日期倒序排列，最后只取前 3 篇
const allPosts = await getCollection("blog");
const recentPosts = allPosts
	.sort((a, b) => {
		const dateA = a.data.date ? new Date(a.data.date).valueOf() : 0;
		const dateB = b.data.date ? new Date(b.data.date).valueOf() : 0;
		return dateB - dateA; // 最新发布的排在最前
	})
	.slice(0, 3); // 🌟 核心：切片函数，只保留前 3 篇
---

<section id="recent-blog">
	<div class="container">
		<!-- 头部标题区 -->
		<div class="section-header">
			<div class="header-left">
				<h2>Stay Updated With Our Tips & Industry News!</h2>
			</div>
			<div class="header-right">
				<span class="sub-title">Our Blog</span>
				<p>Stay informed with our latest sustainable bamboo insights, manufacturing updates, and expert advice.</p>
				<a href="/blog/" class="view-all-link">All news ➔</a>
			</div>
		</div>

		<hr class="section-divider" />

		<!-- 3篇博客卡片网格 -->
		<div class="blog-grid">
			{
				recentPosts.map((post) => {
					// 格式化日期显示（例如：Jul 4, 2026）
					const formattedDate = post.data.date 
						? new Date(post.data.date).toLocaleDateString('en-US', {
								month: 'short',
								day: 'numeric',
								year: 'numeric'
						  })
						: "";

					// 🌟 安全获取图片路径：如果是对象则取 .src，如果是字符串直接用，没有则用默认图
					const imageSrc = post.data.image 
						? (typeof post.data.image === 'object' ? post.data.image.src : post.data.image)
						: "/assets/images/default-blog.jpg";

					return (
						<article class="blog-card">
							<div class="image-wrapper">
								<a href={`/blog/${post.slug}/`}>
									<img 
										src={imageSrc} 
										alt={post.data.title}
										loading="lazy"
									/>
								</a>
							</div>
							
							<div class="card-meta">
								{post.data.tags && post.data.tags[0] && (
									<span class="category-badge">{post.data.tags[0]}</span>
								)}
								<span class="post-date">{formattedDate}</span>
							</div>

							<h3 class="card-title">
								<a href={`/blog/${post.slug}/`}>{post.data.title}</a>
							</h3>

							<p class="card-description">
								{post.data.description || post.body?.slice(0, 100) + "..."}
							</p>

							<a href={`/blog/${post.slug}/`} class="read-more-btn">
								Read more ↗
							</a>
						</article>
					);
				})
			}
		</div>
	</div>
</section>

<style>
	/* ==========================================================================
	   1. 基础布局与头部区域 (优化后：向 FAQ 的字号与视觉分量看齐)
	   ========================================================================== */
	#recent-blog {
		padding: 60px 0;
		background-color: #ffffff;
	}
	.container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 20px;
	}
	.section-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		flex-wrap: wrap;
		gap: 20px;
	}
	.header-left h2 {
		font-size: 2.5rem;
		font-weight: 800;
		max-width: 550px;
		line-height: 1.2;
		margin: 0;
		color: #111111;
		letter-spacing: -0.02em;
	}
	.header-right {
		max-width: 500px;
		position: relative;
	}
	.sub-title {
		font-size: 1.1rem;
		font-weight: 700;
		color: #333333;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		display: block;
		margin-bottom: 5px;
	}
	.header-right p {
		font-size: 1.125rem;
		line-height: 1.6;
		color: #4a4a4a;
		margin: 8px 0 15px 0;
	}
	.view-all-link {
		color: #7ca922;
		text-decoration: none;
		font-weight: 600;
		font-size: 1.05rem;
		position: absolute;
		top: 0;
		right: 0;
	}
	.section-divider {
		border: 0;
		height: 1px;
		background-color: #cbd5e1;
		margin: 30px 0;
	}

	/* ==========================================================================
	   2. 博客网格布局 (控制卡片等高与对齐)
	   ========================================================================== */
	.blog-grid {
		display: grid !important;
		grid-template-columns: repeat(3, 1fr) !important;
		gap: 30px !important;
	}
	.blog-card {
		display: flex !important;
		flex-direction: column !important;
		height: 100% !important;
	}

	/* ==========================================================================
	   3. 卡片内部元素样式 (图片严格统一尺寸)
	   ========================================================================== */
	.image-wrapper {
		width: 100% !important;
		display: block !important;
		position: relative !important;
		border-radius: 12px !important;
		overflow: hidden !important;
		aspect-ratio: 16 / 9 !important;
		margin-bottom: 15px !important;
	}
	.image-wrapper img {
		position: absolute !important;
		top: 0 !important;
		left: 0 !important;
		width: 100% !important;
		height: 100% !important;
		object-fit: cover !important;
		transition: transform 0.3s ease !important;
	}
	.image-wrapper:hover img {
		transform: scale(1.05) !important;
	}
	.card-meta {
		display: flex;
		align-items: center;
		gap: 15px;
		margin-bottom: 10px;
		font-size: 0.85rem;
		color: #64748b;
	}
	.category-badge {
		border: 1px solid #1a1a1a;
		padding: 2px 10px;
		border-radius: 20px;
		text-transform: uppercase;
		font-size: 0.75rem;
		font-weight: 600;
		color: #1a1a1a;
	}

	/* 限制标题为单行，超出显示省略号 */
	.card-title {
		font-size: 1.25rem;
		font-weight: 700;
		margin: 0 0 10px 0;
		line-height: 1.4;
		display: block !important;
		white-space: nowrap !important;
		overflow: hidden !important;
		text-overflow: ellipsis !important;
	}
	.card-title a {
		color: #1a1a1a;
		text-decoration: none;
		display: block !important;
		white-space: nowrap !important;
		overflow: hidden !important;
		text-overflow: ellipsis !important;
	}
	.card-title a:hover {
		color: #7ca922;
	}

	/* 简介文本：自动撑开剩余空间，并限制最多显示 3 行 */
	.card-description {
		color: #475569;
		font-size: 0.95rem;
		line-height: 1.5;
		margin: 0 0 20px 0;
		flex-grow: 1 !important;
		display: -webkit-box !important;
		-webkit-line-clamp: 3 !important;
		-webkit-box-orient: vertical !important;
		overflow: hidden !important;
	}

	/* 按钮样式：始终在卡片最底部水平对齐 */
	.read-more-btn {
		align-self: flex-start !important;
		border: 1px solid #1a1a1a;
		padding: 6px 18px;
		border-radius: 6px;
		color: #1a1a1a;
		text-decoration: none;
		font-size: 0.9rem;
		font-weight: 500;
		transition: all 0.2s ease;
		margin-top: auto !important;
	}
	.read-more-btn:hover {
		background-color: #1a1a1a;
		color: #ffffff;
	}

	/* ==========================================================================
	   4. 响应式断点 (适配平板和手机端)
	   ========================================================================== */
	@media (max-width: 992px) {
		.blog-grid {
			grid-template-columns: repeat(2, 1fr) !important;
		}
	}
	@media (max-width: 768px) {
		.blog-grid {
			grid-template-columns: 1fr !important;
		}
		.view-all-link {
			position: static !important;
			display: inline-block !important;
			margin-top: 10px !important;
		}
		.header-left h2 {
			font-size: 2rem;
		}
	}
</style>